{
    "id" : "me.fouquet.Stencil",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command" : "stencil",
    "finish-args" : [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=host",
        "--filesystem=xdg-run/gvfs",
        "--talk-name=org.gtk.vfs.*"
    ],
    "build-options" : {
        "append-path" : "/usr/lib/sdk/rust-stable/bin",
        "env" : {
            "CARGO_NET_OFFLINE" : "true"
        }
    },
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "stencil",
            "buildsystem" : "meson",
            "config-opts" : [
                "--libdir=lib"
            ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://codeberg.org/fouquet/Stencil.git",
                    "tag" : "v1.0.1",
                    "commit" : "331a502e0921dec662e3449b25586497e852feed"
                },
                "cargo-sources.json",
                {
                    "type" : "shell",
                    "commands" : [
                        "mkdir -p .cargo",
                        "cp cargo/config .cargo/config"
                    ]
                }
            ]
        }
    ]
}
